# Copy this file to .env and adjust if needed.

# Postgres connection string.
# If you're using the included docker-compose.yml as-is, this default works out of the box.
DATABASE_URL=postgresql://codeflow:codeflow@localhost:5432/codeflow

# Node environment
NODE_ENV=development

# Logging level for the API server (trace | debug | info | warn | error)
LOG_LEVEL=info
